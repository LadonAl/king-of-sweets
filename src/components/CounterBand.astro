---
import { Image } from 'astro:assets';
import counter from '../assets/counter.webp';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<div class="relative max-h-[420px] overflow-hidden border-y border-hairline">
  <Image src={counter} alt={t.counter.alt} widths={[768, 1280, 1720]} sizes="100vw" class="band-img" />
  <div
    class="absolute inset-x-0 bottom-0 bg-linear-to-t from-ink/75 via-ink/30 to-transparent pt-16 pb-5"
    aria-hidden="true"
  >
  </div>
  <p
    class="container-site absolute inset-x-0 bottom-4 font-display text-2xl font-bold text-cream text-shadow-sm ltr:text-left rtl:text-right"
  >
    {t.counter.caption}
  </p>
</div>

<style>
  .band-img {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
</style>
