---
import { Image } from 'astro:assets';
import counter from '../assets/counter.webp';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<div class="band">
  <Image src={counter} alt={t.counter.alt} widths={[768, 1280, 1720]} sizes="100vw" />
</div>

<style>
  .band {
    max-height: 420px;
    overflow: hidden;
    border-block: 1px solid var(--hairline);
  }

  .band img {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
</style>
