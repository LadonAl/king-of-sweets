---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { site } from '../data/site';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<footer class="flex flex-wrap items-center justify-between gap-5 bg-ink px-[6vw] py-11 text-cream/80">
  <div class="flex items-center gap-2.5">
    <Image src={logo} alt="King of Sweets logo" width="80" height="80" class="h-10 w-10 shrink-0 object-contain brightness-160" />
    <div class="flex flex-col leading-[1.1]">
      <span class="font-display text-[17px] font-bold text-cream">{lang === 'ar' ? site.nameAr : site.name}</span>
      <span class="font-arabic text-xs text-gold">{t.footer.sub}</span>
    </div>
  </div>
  <div class="text-sm text-cream/60">{t.footer.line}</div>
</footer>
