---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import hero from '../assets/hero.webp';
import { site } from '../data/site';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
const heroTitle = lang === 'ar' ? site.nameAr : site.name;
const heroSub = lang === 'ar' ? site.name : site.nameAr;
---

<section id="top" class="hero">
  <div class="hero-bg">
    <Image
      src={hero}
      alt={t.hero.imgAlt}
      class="hero-img"
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-scrim"></div>
  </div>

  <div class="hero-content">
    <Image src={logo} alt="King of Sweets crest" width="220" height="220" class="hero-crest" />
    <div class="hero-ar">{heroSub}</div>
    <h1>{heroTitle}</h1>
    <p>{t.hero.tagline}</p>
    <div class="hero-actions">
      <a href={site.mapUrl} target="_blank" rel="noopener" class="btn btn-gold">{t.hero.visitCta}</a>
      <a href="#order" class="btn btn-outline-cream">{t.hero.orderCta}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.95) sepia(0.15) hue-rotate(-8deg) brightness(1.08) contrast(0.95);
    opacity: 0.88;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, var(--scrim-mid) 0%, var(--scrim-light) 50%, transparent 100%);
    pointer-events: none;
  }

  :global(html[dir='rtl']) .hero-scrim {
    background: linear-gradient(-100deg, var(--scrim-mid) 0%, var(--scrim-light) 50%, transparent 100%);
  }

  .hero-content {
    position: relative;
    max-width: 640px;
    padding: 60px 6vw;
    color: var(--cream);
  }

  .hero-crest {
    display: block;
    width: 110px;
    height: auto;
    object-fit: contain;
    margin-bottom: 4px;
    filter: brightness(1.7) contrast(1.15) saturate(1.2) drop-shadow(0 0 30px oklch(0.74 0.13 78 / 0.6));
  }

  .hero-ar {
    font-family: var(--font-arabic);
    font-size: 26px;
    color: var(--gold);
    letter-spacing: 0.5px;
    margin-bottom: 10px;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5.6vw, 60px);
    line-height: 1.05;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 18px;
  }

  :global(html[dir='rtl']) h1 {
    line-height: 1.3;
  }

  p {
    font-size: 19px;
    line-height: 1.55;
    color: var(--cream-text);
    margin: 0 0 28px;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
</style>
