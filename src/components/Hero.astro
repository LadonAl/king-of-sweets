---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import hero from '../assets/hero.webp';
import { site } from '../data/site';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
const heroTitle = lang === 'ar' ? site.nameAr : site.name;
const heroSub = lang === 'ar' ? site.name : site.nameAr;
---

<section id="top" class="relative flex min-h-[88vh] items-center">
  <div class="absolute inset-0 overflow-hidden">
    <Image
      src={hero}
      alt={t.hero.imgAlt}
      class="hero-img h-full w-full object-cover"
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-scrim pointer-events-none absolute inset-0" aria-hidden="true"></div>
  </div>

  <div class="relative max-w-2xl px-[6vw] py-15 text-cream">
    <Image
      src={logo}
      alt="King of Sweets crest"
      width="220"
      height="220"
      class="hero-crest mb-1 block h-auto w-[110px] object-contain"
    />
    <div class="mb-2.5 font-arabic text-[26px] tracking-[0.5px] text-gold">{heroSub}</div>
    <h1
      class="mb-4.5 font-display text-[clamp(36px,5.6vw,60px)] leading-[1.05] font-bold tracking-[2px] text-gold uppercase rtl:leading-[1.3]"
    >
      {heroTitle}
    </h1>
    <p class="mb-7 max-w-[520px] text-[19px] leading-relaxed text-cream/90">{t.hero.tagline}</p>
    <div class="flex flex-wrap gap-3.5">
      <a
        href={site.mapUrl}
        target="_blank"
        rel="noopener"
        class="rounded-full bg-gold px-7 py-[15px] text-[15px] font-semibold text-ink no-underline transition-[filter] hover:brightness-108"
        >{t.hero.visitCta}</a
      >
      <a
        href="#order"
        class="rounded-full border-[1.5px] border-cream/60 px-7 py-[15px] text-[15px] font-semibold text-cream no-underline transition-colors hover:bg-cream/10"
        >{t.hero.orderCta}</a
      >
    </div>
  </div>
</section>

<style>
  .hero-img {
    filter: saturate(0.95) sepia(0.15) hue-rotate(-8deg) brightness(1.08) contrast(0.95);
    opacity: 0.88;
  }

  /* Overlay so text stays legible over the photograph, at every width */
  .hero-scrim {
    background:
      linear-gradient(100deg, oklch(0.22 0.02 40 / 0.72) 0%, oklch(0.22 0.02 40 / 0.38) 48%, oklch(0.22 0.02 40 / 0.08) 100%);
  }

  :global(html[dir='rtl']) .hero-scrim {
    background:
      linear-gradient(-100deg, oklch(0.22 0.02 40 / 0.72) 0%, oklch(0.22 0.02 40 / 0.38) 48%, oklch(0.22 0.02 40 / 0.08) 100%);
  }

  .hero-crest {
    filter: brightness(1.7) contrast(1.15) saturate(1.2) drop-shadow(0 0 30px oklch(0.74 0.13 78 / 0.6));
  }
</style>
