---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Ribbon from './Ribbon.astro';
import { menuItems, tagColors } from '../data/site';
import { useT } from '../i18n';
import kunafa from '../assets/menu-kunafa.webp';
import cheese from '../assets/menu-cheese.webp';
import baqlawa from '../assets/menu-baqlawa.webp';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);

const photos: Record<string, ImageMetadata> = { kunafa, cheese, baqlawa };
---

<section id="menu">
  <Ribbon size="small" />
  <div class="inner">
    <div class="section-head">
      <div class="kicker">{t.menu.kicker}</div>
      <h2 class="section-title">{t.menu.title}</h2>
      <p class="sub">{t.menu.sub}</p>
    </div>

    <div class="cards">
      {
        menuItems.map((item) => (
          <div class="card">
            <div class="card-photo">
              <Image
                src={photos[item.id]}
                alt={`${item.name} — ${item.nameAr}`}
                widths={[400, 800, 1200]}
                sizes="(max-width: 700px) 90vw, 400px"
              />
            </div>
            <div class="card-body">
              <div class="card-title">
                <h3>{lang === 'ar' ? item.nameAr : item.name}</h3>
                <span class="card-ar">{lang === 'ar' ? item.name : item.nameAr}</span>
              </div>
              <p>{t.menu.items[item.id]}</p>
              <div class="tags">
                {item.tags.map((tag) => (
                  <span class="tag" style={`background:${tagColors[tag].bg};color:${tagColors[tag].fg}`}>
                    <span class="dot" style={`background:${tagColors[tag].fg}`} />
                    {t.menu.tags[tag]}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <p class="allergy">{t.menu.allergyNote}</p>
  </div>
</section>

<style>
  section {
    position: relative;
    padding: 100px 6vw;
    padding-inline-end: calc(6vw + 130px);
    background: var(--panel);
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-head {
    text-align: center;
    margin-bottom: 12px;
  }

  .section-head h2 {
    margin: 8px 0 12px;
  }

  .sub {
    font-size: 16px;
    color: var(--ink-soft);
    max-width: 560px;
    margin: 0 auto 40px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
  }

  .card {
    background: var(--bg);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
  }

  .card-photo {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .card-title {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    margin: 0;
    color: var(--ink);
  }

  .card-ar {
    font-family: var(--font-arabic);
    font-size: 14px;
    color: var(--gold);
  }

  .card-body p {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .tag {
    font-size: 11.5px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;
  }

  .allergy {
    text-align: center;
    font-size: 13px;
    color: var(--ink-soft);
    margin: 28px 0 0;
  }

  @media (max-width: 1100px) {
    section {
      padding-inline-end: 6vw;
    }
  }
</style>
