---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { menuItems, tagColors } from '../data/site';
import { useT } from '../i18n';
import kunafa from '../assets/menu-kunafa.webp';
import cheese from '../assets/menu-cheese.webp';
import baqlawa from '../assets/menu-baqlawa.webp';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);

const photos: Record<string, ImageMetadata> = { kunafa, cheese, baqlawa };
---

<section id="menu" class="section-pad bg-shade bg-mosaic">
  <div class="container-site">
    <div class="text-center">
      <div class="font-arabic text-sm tracking-[1.5px] text-gold uppercase rtl:font-body rtl:font-bold">
        {t.menu.kicker}
      </div>
      <h2 class="mt-2 mb-3 font-display text-[clamp(30px,4vw,42px)] font-bold text-balance text-maroon">
        {t.menu.title}
      </h2>
      <p class="mx-auto mb-10 max-w-[560px] text-base text-ink-soft">{t.menu.sub}</p>
    </div>

    <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-7">
      {
        menuItems.map((item) => (
          <div class="flex flex-col overflow-hidden rounded-2xl border border-hairline bg-counter">
            <div class="overflow-hidden" style="aspect-ratio: 4 / 3">
              <Image
                src={photos[item.id]}
                alt={`${item.name} — ${item.nameAr}`}
                widths={[400, 800, 1200]}
                sizes="(max-width: 700px) 90vw, 400px"
                class="h-full w-full object-cover"
              />
            </div>
            <div class="flex flex-1 flex-col gap-2.5 px-5.5 pt-5 pb-6">
              <div class="flex items-baseline justify-between gap-2">
                <h3 class="font-display text-2xl font-bold text-ink">{lang === 'ar' ? item.nameAr : item.name}</h3>
                <span class="font-arabic text-sm text-gold">{lang === 'ar' ? item.name : item.nameAr}</span>
              </div>
              <p class="flex-1 text-[15px] leading-relaxed text-ink-soft">{t.menu.items[item.id]}</p>
              <div class="mt-1 flex flex-wrap gap-1.5">
                {item.tags.map((tag) => (
                  <span
                    class="flex items-center gap-[5px] rounded-full px-2.5 py-[5px] text-xs font-semibold"
                    style={`background:${tagColors[tag].bg};color:${tagColors[tag].fg}`}
                  >
                    <span class="inline-block h-1.5 w-1.5 rounded-full" style={`background:${tagColors[tag].fg}`} />
                    {t.menu.tags[tag]}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-7 text-center text-sm text-ink-soft">{t.menu.allergyNote}</p>
  </div>
</section>
