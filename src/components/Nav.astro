---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { site } from '../data/site';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);

const links = [
  ['#story', t.nav.story],
  ['#menu', t.nav.menu],
  ['#order', t.nav.order],
  ['#reviews', t.nav.reviews],
  ['#visit', t.nav.visit],
] as const;
---

<nav
  class="sticky top-0 z-50 flex flex-wrap items-center justify-between gap-x-4 gap-y-0 border-b border-hairline bg-counter/93 px-5 py-3.5 backdrop-blur-md sm:px-8"
>
  <a href="#top" class="flex items-center gap-2.5 text-ink no-underline">
    <Image src={logo} alt="King of Sweets logo" width="88" height="88" class="h-11 w-11 shrink-0 object-contain" />
    <span class="flex flex-col leading-[1.05]">
      <span class="font-[Cormorant_Garamond,serif] text-xl font-bold tracking-[0.5px]">{site.name}</span>
      <span class="font-[Reem_Kufi,sans-serif] text-xs text-gold">{site.nameAr}</span>
    </span>
  </a>

  <div class="order-2 flex items-center gap-3.5">
    <div class="flex items-center gap-0.5 rounded-full border border-hairline bg-shade p-[3px]" aria-label="Language">
      <a
        href="/"
        class:list={[
          'rounded-full px-3.5 py-1.5 text-sm leading-none font-semibold no-underline transition-colors',
          lang !== 'ar' ? 'bg-gold text-ink' : 'text-ink-soft hover:text-maroon',
        ]}
        aria-current={lang !== 'ar' ? 'page' : undefined}>EN</a
      >
      <a
        href="/ar/"
        class:list={[
          'rounded-full px-3.5 pt-2 pb-1 font-[Reem_Kufi,sans-serif] text-sm leading-none font-semibold no-underline transition-colors',
          lang === 'ar' ? 'bg-gold text-ink' : 'text-ink-soft hover:text-maroon',
        ]}
        aria-current={lang === 'ar' ? 'page' : undefined}>عربي</a
      >
    </div>
    <a
      href={site.mapUrl}
      target="_blank"
      rel="noopener"
      class="hidden rounded-full bg-maroon px-4.5 py-2.5 text-sm font-semibold whitespace-nowrap text-cream no-underline transition-colors hover:bg-maroon-dark sm:inline-block"
      >{t.nav.cta}</a
    >
  </div>

  <div
    class="order-3 -mx-1 mt-3 flex w-full items-center gap-5 overflow-x-auto border-t border-hairline px-1 pt-3 text-sm font-medium lg:order-none lg:mx-0 lg:mt-0 lg:w-auto lg:border-0 lg:px-0 lg:pt-0"
  >
    {
      links.map(([href, label]) => (
        <a href={href} class="whitespace-nowrap text-ink no-underline transition-colors hover:text-maroon">
          {label}
        </a>
      ))
    }
  </div>
</nav>
