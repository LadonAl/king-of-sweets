---
import { site } from '../data/site';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<section id="order" class="section-pad">
  <div class="container-site text-center">
    <div class="font-arabic text-sm tracking-[1.5px] text-gold uppercase rtl:font-body rtl:font-bold">
      {t.order.kicker}
    </div>
    <h2 class="mt-2 mb-3.5 font-display text-[clamp(30px,4vw,42px)] font-bold text-balance text-maroon">
      {t.order.title}
    </h2>
    <p class="mx-auto mb-9 max-w-[520px] text-base text-ink-soft">{t.order.sub}</p>
    <div class="flex flex-wrap justify-center gap-4.5">
      <a
        href={site.uberUrl}
        target="_blank"
        rel="noopener"
        class="min-w-[180px] rounded-xl bg-maroon px-7 py-4 text-[15px] font-semibold text-cream no-underline transition-colors hover:bg-maroon-dark"
        >{t.order.uber}</a
      >
      <a
        href={site.deliverooUrl}
        target="_blank"
        rel="noopener"
        class="min-w-[180px] rounded-xl bg-gold px-7 py-4 text-[15px] font-semibold text-ink no-underline transition-[filter] hover:brightness-108"
        >{t.order.deliveroo}</a
      >
      <a
        href={site.justEatUrl}
        target="_blank"
        rel="noopener"
        class="min-w-[180px] rounded-xl border-[1.5px] border-maroon px-7 py-4 text-[15px] font-semibold text-maroon no-underline transition-colors hover:bg-shade"
        >{t.order.justEat}</a
      >
    </div>
  </div>
</section>
