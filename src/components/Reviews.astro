---
import Ribbon from './Ribbon.astro';
import { reviews } from '../data/site';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<section id="reviews">
  <Ribbon size="small" />
  <div class="inner">
    <div class="kicker">{t.reviews.kicker}</div>
    <h2 class="section-title">{t.reviews.title}</h2>
    <div class="cards">
      {
        reviews.map((rev) => (
          <div class="card" dir="ltr">
            <div class="stars">★★★★★</div>
            <p>"{rev.quote}"</p>
            <div class="who">
              {rev.name} <span>· {t.reviews.source}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    position: relative;
    padding: 90px 6vw;
    padding-inline-end: calc(6vw + 130px);
    background: var(--panel);
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    margin: 8px 0 40px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .card {
    background: var(--bg);
    border-radius: 14px;
    padding: 26px;
    border: 1px solid var(--hairline);
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stars {
    color: var(--gold);
    font-size: 16px;
    letter-spacing: 2px;
  }

  .card p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    flex: 1;
  }

  .who {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }

  .who span {
    font-weight: 400;
    color: var(--ink-soft);
  }

  @media (max-width: 1100px) {
    section {
      padding-inline-end: 6vw;
    }
  }
</style>
