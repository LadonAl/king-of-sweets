---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<div
  class="ribbon absolute top-0 z-2 hidden w-[180px] flex-col items-center gap-7 bg-linear-165 from-maroon to-maroon-dark px-4 pt-6 pb-12 min-[1100px]:flex ltr:right-10 rtl:left-10"
  aria-hidden="true"
>
  <div class="h-26 w-26 shrink-0 rotate-45 overflow-hidden rounded-xl border-[3px] border-gold bg-cream">
    <div class="flex h-full w-full -rotate-45 scale-110 items-center justify-center">
      <Image src={logo} alt="" width="180" height="180" class="h-[86%] w-[86%] object-contain" />
    </div>
  </div>
  <div class="text-center">
    <div class="font-display text-2xl leading-[1.2] font-bold text-gold italic rtl:not-italic">{t.ribbon.big}</div>
    <div class="mt-1 font-body text-[10px] tracking-[2px] text-cream/80 uppercase">{t.ribbon.mid}</div>
    <div class="mt-0.5 font-display text-base font-bold text-cream">{t.ribbon.small}</div>
    <div class="mx-auto my-2.5 h-px w-8.5 bg-gold"></div>
    <div class="font-arabic text-xs leading-[1.55] whitespace-pre-line text-gold">{t.ribbon.other}</div>
  </div>
</div>

<style>
  .ribbon {
    clip-path: polygon(0 0, 100% 0, 100% 82%, 50% 100%, 0 82%);
    box-shadow: 0 14px 32px oklch(0.22 0.02 40 / 0.6);
  }
</style>
