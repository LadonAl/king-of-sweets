---
import { Image } from 'astro:assets';
import damascus from '../assets/owner-damascus.webp';
import newcastle from '../assets/owner-newcastle.webp';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<section id="story" class="section-pad relative min-[1100px]:pe-[calc(6vw+210px)]">
  <div class="container-site">
    <div class="mb-16 text-center">
      <div class="mb-2.5 font-arabic text-sm tracking-[1.5px] text-gold uppercase rtl:font-body rtl:font-bold">
        {t.story.kicker}
      </div>
      <h2 class="font-display text-[clamp(30px,4vw,42px)] font-bold text-balance text-maroon">{t.story.title}</h2>
    </div>

    <div class="grid items-center gap-7 md:grid-cols-2 md:gap-16">
      <div>
        <div class="story-photo w-[340px] max-w-full overflow-hidden rounded-[14px]" style="aspect-ratio: 4 / 5">
          <Image
            src={damascus}
            alt={t.story.damascusAlt}
            widths={[400, 680]}
            sizes="(max-width: 800px) 90vw, 340px"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
      <div>
        <div class="mb-2 font-arabic text-sm tracking-[1.5px] text-gold uppercase rtl:font-body rtl:font-bold">
          {t.story.damascusKicker}
        </div>
        <h3 class="mb-4 font-display text-2xl font-bold text-ink">{t.story.damascusTitle}</h3>
        <p class="mb-4 text-[17px] leading-[1.75] text-ink-soft">{t.story.damascusP1}</p>
        <p class="text-[17px] leading-[1.75] text-ink-soft">{t.story.damascusP2}</p>
      </div>
    </div>

    <div class="mt-14 grid items-center gap-7 md:mt-20 md:grid-cols-2 md:gap-16">
      <div class="md:order-2">
        <div class="story-photo ms-auto w-[340px] max-w-full overflow-hidden rounded-[14px]" style="aspect-ratio: 4 / 5">
          <Image
            src={newcastle}
            alt={t.story.newcastleAlt}
            widths={[400, 680]}
            sizes="(max-width: 800px) 90vw, 340px"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
      <div class="md:order-1">
        <div class="mb-2 font-arabic text-sm tracking-[1.5px] text-gold uppercase rtl:font-body rtl:font-bold">
          {t.story.newcastleKicker}
        </div>
        <h3 class="mb-4 font-display text-2xl font-bold text-ink">{t.story.newcastleTitle}</h3>
        <p class="text-[17px] leading-[1.75] text-ink-soft">{t.story.newcastleP1}</p>
        <p class="mt-6 font-display text-[19px] text-maroon italic rtl:not-italic">{t.story.newcastleQuote}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .story-photo {
    filter: contrast(1.08) saturate(1.12) brightness(1.03);
  }
</style>
