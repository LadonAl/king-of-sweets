---
import { Image } from 'astro:assets';
import storefront from '../assets/storefront.webp';
import { site } from '../data/site';
import { useT } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useT(lang);
---

<section id="visit" class="section-pad">
  <div class="container-site grid items-center gap-8 md:grid-cols-[1.1fr_1fr] md:gap-14">
    <div>
      <div class="font-arabic text-sm tracking-[1.5px] text-gold uppercase rtl:font-body rtl:font-bold">
        {t.visit.kicker}
      </div>
      <h2 class="mt-2 mb-5.5 font-display text-[clamp(30px,4vw,42px)] font-bold text-balance text-maroon">
        {t.visit.title}
      </h2>
      <div class="mb-7.5 flex flex-col gap-4 text-base text-ink-soft">
        <div>
          <strong class="text-ink">{t.visit.addressLabel}</strong><br />
          <span dir="ltr">{site.address}</span>
        </div>
        <div>
          <strong class="text-ink">{t.visit.hoursLabel}</strong><br />
          {
            t.visit.hours.map((h) => (
              <span>
                {h.days} · {h.time}
                <br />
              </span>
            ))
          }
        </div>
        <div>
          <strong class="text-ink">{t.visit.phoneLabel}</strong><br />
          <a href={`tel:${site.phone}`} class="font-semibold text-maroon no-underline hover:underline" dir="ltr"
            >{site.phoneDisplay}</a
          >
        </div>
      </div>
      <a
        href={site.mapUrl}
        target="_blank"
        rel="noopener"
        class="inline-block rounded-full bg-maroon px-7 py-4 text-[15px] font-semibold text-cream no-underline transition-colors hover:bg-maroon-dark"
        >{t.visit.directions}</a
      >
    </div>
    <div class="overflow-hidden rounded-2xl" style="aspect-ratio: 4 / 3">
      <Image
        src={storefront}
        alt={t.visit.storefrontAlt}
        widths={[500, 900, 1320]}
        sizes="(max-width: 900px) 90vw, 560px"
        class="h-full w-full object-cover"
      />
    </div>
  </div>
</section>
